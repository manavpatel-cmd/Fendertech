CompileFlags:
  CompilationDatabase: firmware/esp32
  Compiler: /Users/manavpatel/.platformio/packages/toolchain-xtensa-esp32/bin/xtensa-esp32-elf-g++
  Remove:
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -mfix-esp32-psram-cache-issue
    - -fno-jump-tables
    - -fno-tree-loop-distribute-patterns
    - -Werror=all
    - -Werror=extra
    - -Werror=unused-function


